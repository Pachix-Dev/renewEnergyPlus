---
import Layout from "../layouts/Layout.astro";
import i18next, { t, changeLanguage } from "i18next";

changeLanguage("es");

const base = i18next.language === "es" ? "" : `/${i18next.language}`;
---

<Layout
  title="RE+ MEXICO | Nosotros"
  description="Conoce más sobre RE+ México, la comunidad líder en energías renovables en México y América Latina. Descubre nuestra misión, visión y cómo estamos impulsando el futuro energético sostenible."
>
  <section class="bg-gradient-to-b from-gray-50 to-white">
    <!-- HERO -->
    <div
      class="bg-[url('/img/imagen2027/bg_hero_about.jpg')] min-h-80 bg-cover bg-center flex items-center justify-center"
    >
      <div
        class="text-center max-w-4xl mx-auto flex flex-col items-center justify-center h-full py-20 px-4 text-white"
        data-aos="fade-down"
        data-aos-duration="1000"
      >
        <h1 class="text-3xl sm:text-4xl lg:text-6xl font-black mb-6 leading-tight px-2">
          {t("AboutSSM.title")}
        </h1>
        <div class="w-32 h-1 bg-white mx-auto rounded-full"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-10 max-w-7xl mx-auto px-4 py-6 sm:py-10">
      <div class=" bg-white p-4 flex flex-col gap-4 relative shadow-lg rounded-lg border border-gray-100">
        <img
            src="/img/imagen2027/ray.webp"
            alt=""
            class="absolute top-0 left-1/2 z-10 w-16 sm:w-24 -translate-x-1/2 -translate-y-1/3"
          />
        <div class="flex justify-center pt-10 sm:pt-20">
          <h2
            class="text-4xl sm:text-5xl font-extrabold uppercase text-center text-[#3333FF]"
          >
          {i18next.language === "es" ? "Nuestra Misión" : "Our Mission"}
          </h2>
        </div>
        <p class="text-gray-800 text-justify p-4 sm:p-6 lg:p-10 leading-relaxed" 
          set:html={t("AboutSSM.description")}
        />
        <div class="text-lg font-semibold leading-relaxed bg-[#3333FF] p-4 rounded-lg text-white text-center uppercase"
          set:html={t("AboutSSM.description2")}
        />
      </div>
      <div class="flex flex-col items-center gap-4 w-auto p-4">
        <img
          src="/img/gallery/2026/DSC07127.webp"
          alt="Replus México - Evento de Energías Renovables"
          class="w-full max-w-[500px] aspect-[5/3] object-cover shadow-lg"
        />
        <img
          src="/img/gallery/2026/DSC07751.webp"
          alt="Replus México - Evento de Energías Renovables"
          class="w-full max-w-[500px] aspect-[5/3] object-cover shadow-lg"
        />
        <img
          src="/img/gallery/2026/DSC07016.webp"
          alt="Replus México - Evento de Energías Renovables"
          class="w-full max-w-[500px] aspect-[5/3] object-cover shadow-lg"
        />
      </div>
    </div>
  </section>
</Layout>
