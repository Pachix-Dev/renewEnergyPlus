---
import i18next, { changeLanguage, t } from "i18next";
import LayoutRegister from "../layouts/LayoutRegister.astro";
import { sponsors } from "../data/constanst_logos.js";
import MarqueeSponsors from "../components/register/MarqueeSponsors.astro";
import { PreValidation } from "../components/register/PreValidation";

changeLanguage("es");

const registerTranslations = t("register", { returnObjects: true });
const currentLanguage = i18next.language;
const base = currentLanguage === "es" ? "" : `/${currentLanguage}`;
---

<LayoutRegister title="RE+ MEXICO | Registro">
  <main
    class="min-h-screen max-md:container mx-auto md:flex items-start justify-center md:p-5 gap-5"
  >
    <div class="md:w-1/2 bg-white overflow-hidden rounded-2xl shadow-2xl">
      {/* Panel Izquierdo - Formulario */}
      <div class="p-12 bg-white">
        {/* Título */}
        <div class="mb-4 text-center md:text-left">
          <h1 class="font-extrabold text-4xl">
            {t("register.title")}
          </h1>
          <p class="text-gray-600 font-bold text-sm">
            {t("register.welcome")}
          </p>
        </div>

        <!-- Programa Premium -->
        <div class="mt-4 relative overflow-hidden rounded-3xl text-white shadow-2xl min-h-[240px]">
          <img
            src="/img/conferencias_premium.webp"
            alt={t("register.premium_alt")}
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div
            class="absolute inset-0 bg-gradient-to-tr from-violet-500/95 via-[#1b1632]/75 to-[#1b1632]/55"
          >
          </div>
          <div
            class="absolute inset-0 bg-[radial-gradient(circle_at_100%_0%,rgba(235,179,88,0.35),transparent_42%)]"
          >
          </div>
          <div
            class="absolute inset-0 bg-[linear-gradient(to_top,rgba(11,9,20,0.82),rgba(11,9,20,0.2))]"
          >
          </div>

          <div class="relative z-10 p-4 md:p-5 flex h-full items-end">
            <div class="max-w-2xl text-center md:text-left">
              <p
                class="mt-2 text-xl md:text-2xl font-extrabold leading-tight uppercase tracking-wide"
              >
                {t("register.premium_title")}
              </p>
              <p
                class="mt-2 text-xs font-semibold tracking-wider uppercase text-white/75"
              >
                {t("register.premium_includes")}
              </p>
              <div
                class="mt-2 flex flex-wrap justify-center md:justify-start gap-2 text-[12px] font-bold tracking-wide uppercase"
              >
                <div
                  class="px-2.5 py-1 rounded-full font-semibold bg-white/12 border border-white/20 backdrop-blur-sm"
                >
                  {t("register.premium_item_1")}
                </div>
                <div
                  class="px-2.5 py-1 rounded-full font-semibold bg-white/12 border border-white/20 backdrop-blur-sm"
                >
                  {t("register.premium_item_2")}
                </div>
                <div
                  class="px-2.5 py-1 rounded-full font-semibold bg-white/12 border border-white/20 backdrop-blur-sm"
                >
                  {t("register.premium_item_3")}
                </div>
                <div
                  class="px-2.5 py-1 rounded-full font-semibold bg-white/12 border border-white/20 backdrop-blur-sm"
                >
                  {t("register.premium_item_4")}
                </div>
              </div>
              <div class="flex flex-col md:flex-row py-2">
                <div
                  class="inline-flex flex-col items-center md:items-start gap-1.5 px-4 py-2 rounded-xl text-[#e8aa35]"
                >
                  <span
                    class="text-[11px] md:text-xs font-extrabold tracking-wider uppercase"
                  >
                    {t("register.premium_presale")}
                  </span>
                  <span class="text-2xl md:text-3xl font-black leading-none">
                    {t("register.premium_price")}
                    <span class="text-sm md:text-base font-bold align-middle">
                      {t("register.premium_currency")}</span
                    >
                  </span>
                </div>
                <a
                  href={`${base}/programa-premium-productos`}
                  class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-[#ffd27a] via-[#f3bc56] to-[#e8aa35] hover:from-[#ffe29f] hover:via-[#f7c86f] hover:to-[#efba56] text-[#2b2136] px-6 py-3 rounded-xl font-black tracking-wide border-2 border-white/80 shadow-[0_10px_25px_rgba(235,179,88,0.45)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_14px_30px_rgba(235,179,88,0.6)] uppercase"
                >
                  {t("register.premium_cta")}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        {/* Formulario de Registro */}
        <div
          class="mt-8 flex flex-wrap items-center justify-center md:justify-start gap-4 font-bold"
        >
          {t("register.first_time")}
          <a
            href={`${base}/registro-nuevo`}
            class="bg-[#6C6598] hover:bg-[#5a5484] hover:scale-110 ease-in-out duration-200 text-white px-4 py-2 rounded-xl flex items-center gap-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z"
              ></path>
            </svg>
            {t("register.button")}</a
          >
        </div>

        {/* Reimpresión de Gafete */}
        <div
          class="mt-6 p-4 border rounded-xl bg-gray-50 flex flex-wrap items-center justify-center md:justify-between gap-4 text-center md:text-left"
        >
          <p class="text-gray-700 font-medium">
            {t("home.register.reprint_hint")}
          </p>
          <a
            href={`${base}/reimprimir-gafete`}
            class="shrink-0 bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-bold"
          >
            {t("home.register.reprint_button")}
          </a>
        </div>

        <!-- Mensaje de medios -->
        <div
          class="mt-8 p-4 border rounded-xl bg-yellow-100 text-yellow-800 text-center"
        >
          <p class="font-bold text-sm md:text-base">
            {t("register.media_messege")}
            <a href="mailto:social.media@igeco.mx"> social.media@igeco.mx </a>
          </p>
        </div>

        {/* Formulario de actualizanción de datos */}
        <PreValidation
          client:only="react"
          translates={registerTranslations}
          currentLanguage={currentLanguage}
        />
      </div>
    </div>

    {/* Panel Derecho - Diseño Visual */}
    <div
      class="md:w-1/2 bg-gradient-to-r from-[#766EA6] to-[#565078] p-12 text-white relative md:rounded-2xl md:mt-0"
    >
      {/* Círculos decorativos de fondo */}
      <div class="absolute inset-0 overflow-hidden z-0">
        <div
          class="absolute top-10 right-10 w-32 h-32 bg-white bg-opacity-10 rounded-full"
        >
        </div>
        <div
          class="absolute bottom-20 left-10 w-24 h-24 bg-white bg-opacity-5 rounded-full"
        >
        </div>
        <div
          class="absolute top-1/2 right-1/4 w-16 h-16 bg-white bg-opacity-10 rounded-full"
        >
        </div>
      </div>
      {/* Logo */}
      <img src="/img/replusR.webp" alt="RE+ Mexico Logo" class="w-32 mb-8" />
      {/* Contenido Principal */}
      <div class="relative z-10 text-left mb-8">
        <p
          class="font-[Tungsten-Medium] text-white text-3xl lg:text-4xl text-left uppercase font-bold tracking-wider"
        >
          {t("home.slogan")}
        </p>
        <p
          class="font-[Tungsten-Medium] text-white text-3xl lg:text-4xl text-left"
        >
          {t("home.event-date")}
          <span class="">| 2026</span>
        </p>
      </div>

      {/* Tarjeta Simulada */}
      <div class="bg-[#FFFFFF] rounded-2xl p-5 shadow-2xl relative z-10">
        <MarqueeSponsors partners={sponsors} isLeftToRight />
      </div>
      <p class="mt-5 font-bold text-amber-400 text-2xl">
        {t("register.student_register")}
      </p>
      <a
        href="/registro-estudiante"
        class="font-bold bg-amber-400 hover:bg-amber-500 hover:scale-110 ease-in-out duration-200 px-4 py-2 rounded-xl inline-block mt-5 text-white relative z-10"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="inline size-6 mr-2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z"
          ></path>
        </svg>

        {t("register.register_student")}
      </a>
    </div>
  </main>
</LayoutRegister>

<style>
  body {
    background-color: white;
    color: black;
  }
</style>
