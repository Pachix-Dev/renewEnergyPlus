---
import Layout from "../../layouts/Layout.astro";
import i18next, { t, changeLanguage } from "i18next";
import { sponsors } from "../../data/constanst_logos.js";
import MarqueeSponsors from "../../components/register/MarqueeSponsors.astro";
import ProgramaEscenario from "../../components/shared/ProgramaEscenario.astro";
import { ProgramaEscenarioClient } from "../../components/shared/ProgramaEscenarioClient";
import SunsetCocktail from "../../components/SunsetCocktail.astro";
import VipArea from "../../components/VipArea.astro";

changeLanguage("en");

const API_URL = import.meta.env.DEV
    ? "https://dashboard.igeco.mx"
    : "https://dashboard.igeco.mx";
const base = i18next.language === "es" ? "" : `/${i18next.language}`;
---

<Layout title="RE+ MEXICO | programa premium">
  
  <!-- Render dinámico en cliente para datos vivos -->
  <ProgramaEscenarioClient
    client:load
    apiUrl={API_URL}
    language={i18next.language}
    escenarioIndex={0}
    showCompanyLogo={true}
  />

  <!-- Sunset Cocktail Section -->
  <div id="sunsetCocktail">
    <SunsetCocktail />
  </div>

  <div id="vipArea">
    <VipArea />
  </div>

</Layout>
<style>
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }

  /* Mejoras en las sombras de texto */
  h1 {
    text-shadow: 2px 2px 12px rgba(0, 0, 0, 0.8);
  }

  /* Efectos de glassmorphism mejorados */
  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  /* Animaciones personalizadas para los elementos decorativos */
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(180deg);
    }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  /* Responsive improvements */
  @media (max-width: 768px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    /* Ajustes para móviles en ejes temáticos */
    .grid.lg\\:grid-cols-4 {
      grid-template-columns: 1fr;
    }

    .grid.md\\:grid-cols-2 {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) {
    .grid.lg\\:grid-cols-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .modern-card {
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.18);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(94, 88, 132, 0.15);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }

  .modern-card:hover {
    box-shadow: 0 16px 48px 0 rgba(31, 38, 135, 0.28);
    background: rgba(94, 88, 132, 0.25);
    transform: translateY(-6px) scale(1.04);
  }

  .icon-circle {
    transition: transform 0.3s;
    box-shadow: 0 4px 16px 0 rgba(94, 88, 132, 0.25);
  }

  .img-card {
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.18);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(30, 41, 59, 0.15);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 340px;
  }
  .img-card:hover {
    box-shadow: 0 16px 48px 0 rgba(31, 38, 135, 0.28);
    background: rgba(94, 88, 132, 0.25);
    transform: translateY(-6px) scale(1.04);
  }
  .img-card-img {
    width: 100%;
    height: 12rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #5e5884 0%, #1e293b 100%);
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .img-card-img {
      height: 14rem;
    }
  }
  .img-card-content {
    width: 100%;
    padding: 1.5rem 1.5rem;
    background: linear-gradient(
      to bottom,
      rgba(30, 41, 59, 0.7) 0%,
      rgba(94, 88, 132, 0.6) 70%,
      transparent 100%
    );
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1 1 0%;
  }
  .card-modern {
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.18);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(30, 41, 59, 0.1);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 340px;
  }
  .card-modern:hover {
    box-shadow: 0 16px 48px 0 rgba(31, 38, 135, 0.28);
    background: rgba(94, 88, 132, 0.18);
    transform: translateY(-6px) scale(1.04);
  }
  .card-img {
    width: 100%;
    height: 11rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #5e5884 0%, #1e293b 100%);
    overflow: hidden;
    position: relative;
  }
  @media (min-width: 640px) {
    .card-img {
      height: 14rem;
    }
  }

  .premium-card-v2 {
    background: linear-gradient(
      135deg,
      #1e293bcc 0%,
      #5e588499 60%,
      #1e293bcc 100%
    );
    border-radius: 1.25rem;
    border: 2px solid #5e5884;
    box-shadow:
      0 8px 32px 0 rgba(94, 88, 132, 0.18),
      0 0 24px 0 #5e5884aa;
    transition:
      box-shadow 0.4s,
      transform 0.4s;
    overflow: hidden;
    /* min-height eliminado para responsividad */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
  }
  .premium-card-v2:hover {
    box-shadow:
      0 20px 60px 0 #5e5884cc,
      0 0 32px 0 #1e293bcc;
    background: linear-gradient(
      135deg,
      #5e5884cc 0%,
      #1e293b99 60%,
      #1e293bcc 100%
    );
    transform: translateY(-8px) scale(1.04);
  }
  .premium-img-circle {
    box-shadow: 0 4px 24px 0 #5e5884aa;
    border-radius: 9999px;
    background: rgba(30, 41, 59, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      box-shadow 0.3s,
      border 0.3s;
  }
</style>
