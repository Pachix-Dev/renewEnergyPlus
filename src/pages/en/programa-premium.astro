---
import Layout from "../../layouts/Layout.astro";
import i18next, { t, changeLanguage } from "i18next";
import { sponsors } from "../../data/constanst_logos.js";
import MarqueeSponsors from "../../components/register/MarqueeSponsors.astro";
import ProgramaEscenario from "../../components/shared/ProgramaEscenario.astro";
import { ProgramaEscenarioClient } from "../../components/shared/ProgramaEscenarioClient";
import SunsetCocktail from "../../components/SunsetCocktail.astro";
import VipArea from "../../components/VipArea.astro";
import ProductosPremiumPreview from "../../components/ProductosPremiumPreview.astro";
import ProgramaPremiumHero from "../../components/programa2026/ProgramaPremiumHero.astro";
import { KeynoteSpeakersCarousel } from "../../components/programa2026/KeynoteSpeakersCarousel";

changeLanguage("en");

const API_URL = import.meta.env.DEV
    ? "https://dashboard.igeco.mx"
    : "https://dashboard.igeco.mx";
const base = i18next.language === "es" ? "" : `/${i18next.language}`;
const language = i18next.language || "es";
---

<Layout
  title="RE+ MEXICO | PROGRAMA PREMIUM"
  description="Foro especializado en donde líderes del sector energético analizan las tendencias, retos y oportunidades que están definiendo el futuro de la energía en México y el mundo."
>
  <section class="relative overflow-hidden bg-gradient-to-b from-[#0B1224] via-[#0f172a] to-[#1E293B]">
    <!-- Programa Premium Hero -->
    <ProgramaPremiumHero />

    <!-- Keynote Speakers Carousel -->
    <KeynoteSpeakersCarousel language={language} client:load />

    <!-- Boton para descargar Programa Premium -->
    <div class="flex flex-col items-center gap-4 py-12 px-4">
      <!-- Decorative label -->
      <p class="text-amber-400/70 text-xs tracking-[0.3em] uppercase font-semibold">
        {language === "es" ? "Descarga gratuita" : "Free download"}
      </p>

      <a
        href={language === "es" ? "/doc/Programa_Conferencias_Premium_RE+Mexico_2026.pdf" : "/doc/Premium_Conferences_Program_RE+Mexico_2026.pdf"}
        class="group relative inline-flex items-center gap-4 px-10 py-5 rounded-2xl font-extrabold text-base tracking-widest uppercase overflow-hidden text-[#0B1224] transition-all duration-300 hover:scale-105 active:scale-95 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-amber-400/60"
        style="background: linear-gradient(135deg, #f59e0b 0%, #fde68a 45%, #f59e0b 100%); box-shadow: 0 0 30px rgba(251,191,36,0.5), 0 4px 20px rgba(0,0,0,0.4);"
      >
        <!-- Animated glow ring -->
        <span class="absolute inset-0 rounded-2xl pointer-events-none download-pulse-ring"></span>

        <!-- Shimmer sweep -->
        <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/40 to-transparent group-hover:translate-x-full transition-transform duration-700 ease-in-out pointer-events-none rounded-2xl"></span>

        <!-- PDF badge -->
        <span class="relative z-10 flex items-center justify-center w-9 h-9 rounded-lg bg-[#0B1224]/15 text-[10px] font-black tracking-wider shrink-0">
          PDF
        </span>

        <!-- Text block -->
        <span class="relative z-10 flex flex-col leading-tight text-left">
          <span class="text-base font-extrabold">
            DESCARGA PROGRAMA
          </span>
        </span>

        <!-- Animated download arrow -->
        <span class="relative z-10 flex items-center justify-center w-9 h-9 rounded-full bg-[#0B1224]/15 shrink-0 group-hover:bg-[#0B1224]/25 transition-colors duration-300">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 transition-transform duration-300 group-hover:translate-y-0.5 group-hover:animate-bounce"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 3v12m0 0l-4-4m4 4l4-4" />
            <path d="M3 17v2a2 2 0 002 2h14a2 2 0 002-2v-2" />
          </svg>
        </span>
      </a>
    </div>

    <!-- Render dinámico en cliente para datos vivos -->
    <ProgramaEscenarioClient
      client:load
      apiUrl={API_URL}
      language={i18next.language}
      escenarioIndex={0}
      showCompanyLogo={true}
    />

    <!-- Sección de precios -->
    <ProductosPremiumPreview />

    <!-- Sunset Cocktail Section -->
    <!-- <div id="sunsetCocktail">
    <SunsetCocktail />
  </div>

  <div id="vipArea">
    <VipArea />
  </div> -->
  </section>
</Layout>
<style>
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes download-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(251, 191, 36, 0.55), 0 0 30px rgba(251, 191, 36, 0.45);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(251, 191, 36, 0), 0 0 50px rgba(251, 191, 36, 0.65);
    }
  }

  .download-pulse-ring {
    animation: download-pulse 2.4s ease-in-out infinite;
  }

  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }

  /* Mejoras en las sombras de texto */
  h1 {
    text-shadow: 2px 2px 12px rgba(0, 0, 0, 0.8);
  }

  /* Efectos de glassmorphism mejorados */
  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  /* Animaciones personalizadas para los elementos decorativos */
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(180deg);
    }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  /* Responsive improvements */
  @media (max-width: 768px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    /* Ajustes para móviles en ejes temáticos */
    .grid.lg\\:grid-cols-4 {
      grid-template-columns: 1fr;
    }

    .grid.md\\:grid-cols-2 {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) {
    .grid.lg\\:grid-cols-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .modern-card {
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.18);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(94, 88, 132, 0.15);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }

  .modern-card:hover {
    box-shadow: 0 16px 48px 0 rgba(31, 38, 135, 0.28);
    background: rgba(94, 88, 132, 0.25);
    transform: translateY(-6px) scale(1.04);
  }

  .icon-circle {
    transition: transform 0.3s;
    box-shadow: 0 4px 16px 0 rgba(94, 88, 132, 0.25);
  }

  .img-card {
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.18);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(30, 41, 59, 0.15);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 340px;
  }
  .img-card:hover {
    box-shadow: 0 16px 48px 0 rgba(31, 38, 135, 0.28);
    background: rgba(94, 88, 132, 0.25);
    transform: translateY(-6px) scale(1.04);
  }
  .img-card-img {
    width: 100%;
    height: 12rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #5e5884 0%, #1e293b 100%);
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .img-card-img {
      height: 14rem;
    }
  }
  .img-card-content {
    width: 100%;
    padding: 1.5rem 1.5rem;
    background: linear-gradient(
      to bottom,
      rgba(30, 41, 59, 0.7) 0%,
      rgba(94, 88, 132, 0.6) 70%,
      transparent 100%
    );
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1 1 0%;
  }
  .card-modern {
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.18);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(30, 41, 59, 0.1);
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 340px;
  }
  .card-modern:hover {
    box-shadow: 0 16px 48px 0 rgba(31, 38, 135, 0.28);
    background: rgba(94, 88, 132, 0.18);
    transform: translateY(-6px) scale(1.04);
  }
  .card-img {
    width: 100%;
    height: 11rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #5e5884 0%, #1e293b 100%);
    overflow: hidden;
    position: relative;
  }
  @media (min-width: 640px) {
    .card-img {
      height: 14rem;
    }
  }

  .premium-card-v2 {
    background: linear-gradient(
      135deg,
      #1e293bcc 0%,
      #5e588499 60%,
      #1e293bcc 100%
    );
    border-radius: 1.25rem;
    border: 2px solid #5e5884;
    box-shadow:
      0 8px 32px 0 rgba(94, 88, 132, 0.18),
      0 0 24px 0 #5e5884aa;
    transition:
      box-shadow 0.4s,
      transform 0.4s;
    overflow: hidden;
    /* min-height eliminado para responsividad */
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
  }
  .premium-card-v2:hover {
    box-shadow:
      0 20px 60px 0 #5e5884cc,
      0 0 32px 0 #1e293bcc;
    background: linear-gradient(
      135deg,
      #5e5884cc 0%,
      #1e293b99 60%,
      #1e293bcc 100%
    );
    transform: translateY(-8px) scale(1.04);
  }
  .premium-img-circle {
    box-shadow: 0 4px 24px 0 #5e5884aa;
    border-radius: 9999px;
    background: rgba(30, 41, 59, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      box-shadow 0.3s,
      border 0.3s;
  }
</style>
