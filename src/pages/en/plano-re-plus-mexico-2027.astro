---
import Layout from "../../layouts/Layout.astro";
import i18next, { t, changeLanguage } from "i18next";

changeLanguage("en");

const base = i18next.language === "es" ? "" : `/${i18next.language}`;
---

<Layout title='RE+ MEXICO | Plano RE+ 2027'>
  <!-- Hero Section -->
  <section class='relative overflow-hidden bg-[radial-gradient(circle_at_15%_20%,rgba(250,204,21,0.18),transparent_36%),radial-gradient(circle_at_85%_25%,rgba(14,116,144,0.28),transparent_34%),linear-gradient(130deg,#0f172a_10%,#1e293b_48%,#334155_100%)] py-8 md:py-12'>
    <div class='pointer-events-none absolute inset-0'>
      <div class='absolute -left-12 top-8 h-28 w-28 rounded-full bg-cyan-300/10 blur-2xl md:h-44 md:w-44'></div>
      <div class='absolute -right-10 bottom-4 h-32 w-32 rounded-full bg-amber-300/20 blur-2xl md:h-52 md:w-52'></div>
    </div>

    <div class='container relative mx-auto px-4'>
      <div class='mx-auto max-w-6xl rounded-3xl border border-white/15 bg-white/5 px-6 py-8 text-center text-white shadow-[0_25px_80px_rgba(2,6,23,0.45)] backdrop-blur-md md:px-10 md:py-10'>

        <h1 class='text-4xl font-black uppercase leading-tight md:text-6xl'>
          <span class='mb-2 block text-xl font-semibold tracking-[0.18em] text-cyan-100/95 md:text-2xl'>
            RE+ MEXICO 2027
          </span>
          {i18next.language === 'es' ? 'Plano del evento' : 'Event floor plan'}
        </h1>

        <p class='mx-auto mt-4 max-w-4xl text-base text-white/85 md:text-xl'>
          {
            i18next.language === 'es'
              ? 'Explora la distribución completa del evento y planifica tu visita de manera eficiente'
              : 'Explore the complete event layout and plan your visit efficiently'
          }
        </p>

        <div class='mt-6 flex flex-wrap items-center justify-center gap-3'>
          <span class='inline-flex items-center rounded-full border border-white/20 bg-black/20 px-4 py-1.5 text-xs font-medium uppercase tracking-wide text-white/90'>
            {
              i18next.language === 'es'
                ? '20 al 22 de abril, 2027'
                : 'April 20-22, 2027'
            }
          </span>
          <span class='inline-flex items-center rounded-full border border-white/20 bg-black/20 px-4 py-1.5 text-xs font-medium uppercase tracking-wide text-white/90'>
            {i18next.language === 'es' ? 'Expo Guadalajara' : 'Expo Guadalajara'}
          </span>
        </div>
        <!-- horarios del evento -->
        <!-- <div
          class='mt-6 mx-auto max-w-2xl rounded-2xl border border-white/25 bg-white/10 backdrop-blur-md p-4 md:p-5 text-left text-white shadow-lg'
        >
          <div class='flex items-center gap-2 mb-3'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='h-5 w-5 text-amber-300'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'
              ></path>
            </svg>
            <p class='text-sm md:text-base font-bold tracking-wide uppercase'>
              {i18next.language === 'es' ? 'Horario del evento' : 'Event schedule'}
            </p>
          </div>
          <div class='grid gap-2 md:grid-cols-2'>
            <div class='rounded-xl bg-white/15 border border-white/20 px-4 py-3'>
              <p class='text-xs md:text-sm font-semibold text-white/85 uppercase'>
                {
                  i18next.language === 'es'
                    ? 'Martes 14 y Miercoles 15 de abril'
                    : 'Tuesday April 14 and Wednesday April 15'
                }
              </p>
              <p class='text-base md:text-lg font-extrabold text-white'>11:00 - 18:00</p>
            </div>

            <div class='rounded-xl bg-white/15 border border-white/20 px-4 py-3'>
              <p class='text-xs md:text-sm font-semibold text-white/85 uppercase'>
                {i18next.language === 'es' ? 'Jueves 16 de abril' : 'Thursday April 16'}
              </p>
              <p class='text-base md:text-lg font-extrabold text-white'>11:00 - 17:00</p>
            </div>
          </div>
        </div> -->
      </div>
    </div>
  </section>

  <!-- PDF Viewer Section -->
  <section class='bg-[linear-gradient(180deg,#f8fafc_0%,#eef2ff_36%,#f8fafc_100%)] py-12 md:py-16'>
    <div class='container mx-auto px-4'>
      <div class='max-w-7xl mx-auto'>
        <!-- Toolbar -->
        <div
          class='rounded-t-3xl border border-slate-200/70 border-b-0 bg-white/95 p-4 shadow-[0_14px_36px_rgba(15,23,42,0.08)] backdrop-blur-sm md:p-5'
        >
          <div
            class='flex flex-col sm:flex-row items-center justify-between gap-4'
          >
            <div class='flex items-center gap-4'>
              <div class='flex items-center gap-2'>
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  class='h-6 w-6 text-cyan-700'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                  ></path>
                </svg>
                <h2 class='text-xl font-black tracking-tight text-slate-900'>
                  {
                    i18next.language === 'es'
                      ? 'Plano interactivo'
                      : 'Interactive floor plan'
                  }
                </h2>
              </div>

              <div class='hidden sm:flex items-center gap-2 rounded-full bg-emerald-50 px-3 py-1 text-sm text-emerald-700 ring-1 ring-emerald-200'>
                <span class='h-2 w-2 animate-pulse rounded-full bg-emerald-500'></span>
                <span
                  >{
                    i18next.language === 'es'
                      ? 'Documento cargado'
                      : 'Document loaded'
                  }</span
                >
              </div>
            </div>

            <div class='flex items-center gap-3'>
              <!-- Download Button -->
              <a
                href='/doc/RE+_MEX_plano_2027_170726.pdf'
                download
                class='group inline-flex items-center gap-2 rounded-xl bg-slate-900 px-4 py-2 text-white shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:bg-slate-800'
              >
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  class='h-4 w-4 group-hover:translate-y-1 transition-transform duration-300'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                  ></path>
                </svg>
                <span class='font-medium'>
                  {i18next.language === 'es' ? 'Descargar' : 'Download'}
                </span>
              </a>

              <!-- Fullscreen Button -->
              <button
                onclick='toggleFullscreen()'
                class='group inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-white px-4 py-2 text-slate-700 transition-all duration-300 hover:-translate-y-0.5 hover:bg-slate-50'
              >
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  class='h-4 w-4 group-hover:scale-110 transition-transform duration-300'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4'
                  ></path>
                </svg>
                <span class='font-medium hidden sm:inline'>
                  {
                    i18next.language === 'es'
                      ? 'Pantalla completa'
                      : 'Fullscreen'
                  }
                </span>
              </button>
            </div>
          </div>
        </div>

        <!-- PDF Container -->
        <div
          class='relative overflow-hidden rounded-b-3xl border border-slate-200/70 border-t-0 bg-white shadow-[0_22px_55px_rgba(15,23,42,0.16)]'
          id='pdf-container'
        >
          <div class='relative'>
            <!-- Loading Overlay -->
            <div
              id='pdf-loading'
              class='absolute inset-0 z-10 flex items-center justify-center bg-slate-100/95'
            >
              <div class='text-center'>
                <div
                  class='mx-auto mb-4 h-12 w-12 animate-spin rounded-full border-b-2 border-cyan-700'
                >
                </div>
                <p class='font-medium text-slate-600'>
                  {
                    i18next.language === 'es'
                      ? 'Cargando plano...'
                      : 'Loading floor plan...'
                  }
                </p>
              </div>
            </div>

            <!-- PDF Iframe -->
            <iframe
              id='pdf-iframe'
              src='/doc/RE+_MEX_plano_2027_170726.pdf'
              class='w-full h-[82vh] min-h-[560px] border-0 lg:h-[88vh]'
              onload='hidePdfLoading()'
              title={i18next.language === 'es'
                ? 'Plano RE+ Mexico 2027'
                : 'RE+ Mexico 2027 Floor Plan'}></iframe>
          </div>
        </div>

        <!-- Alternative Download Section (Fallback) -->
        <div
          class='mt-8 rounded-3xl border border-slate-200 bg-[linear-gradient(145deg,#ffffff_0%,#f8fafc_56%,#eef2ff_100%)] p-6 shadow-[0_12px_30px_rgba(15,23,42,0.08)] md:p-8'
        >
          <div
            class='flex flex-col md:flex-row items-center justify-between gap-6'
          >
            <div class='flex items-start gap-4'>
              <div
                class='flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-cyan-700/10'
              >
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  class='h-6 w-6 text-cyan-700'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class='mb-2 text-lg font-extrabold text-slate-900'>
                  {
                    i18next.language === 'es'
                      ? '¿No puedes ver el plano?'
                      : "Can't see the floor plan?"
                  }
                </h3>
                <p class='max-w-2xl text-slate-600'>
                  {
                    i18next.language === 'es'
                      ? 'Si tienes problemas para visualizar el documento, puedes descargarlo directamente o abrirlo en una nueva pestaña.'
                      : 'If you have trouble viewing the document, you can download it directly or open it in a new tab.'
                  }
                </p>
              </div>
            </div>

            <div class='flex flex-col sm:flex-row gap-3'>
              <a
                href='/doc/RE+_MEX_plano_2027_170726.pdf'
                target='_blank'
                rel='noopener noreferrer'
                class='group inline-flex items-center gap-2 rounded-xl border border-cyan-700 px-6 py-3 text-cyan-700 transition-colors duration-300 hover:bg-cyan-700 hover:text-white'
              >
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  class='h-4 w-4'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14'
                  ></path>
                </svg>
                <span class='font-medium'>
                  {
                    i18next.language === 'es'
                      ? 'Abrir en nueva pestaña'
                      : 'Open in new tab'
                  }
                </span>
              </a>

              <a
                href='/doc/RE+_MEX_plano_2027_170726.pdf'
                download
                class='group inline-flex items-center gap-2 rounded-xl bg-slate-900 px-6 py-3 text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-slate-800'
              >
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  class='h-4 w-4 group-hover:translate-y-1 transition-transform duration-300'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                  ></path>
                </svg>
                <span class='font-medium'>
                  {i18next.language === 'es' ? 'Descargar PDF' : 'Download PDF'}
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // Función para ocultar el loading del PDF
  function hidePdfLoading() {
    const loading = document.getElementById('pdf-loading')
    if (loading) {
      loading.style.display = 'none'
    }
  }

  // Función para pantalla completa
  function toggleFullscreen() {
    const container = document.getElementById('pdf-container')

    if (!document.fullscreenElement) {
      container.requestFullscreen().catch((err) => {
        console.log(`Error attempting to enable fullscreen: ${err.message}`)
      })
    } else {
      document.exitFullscreen()
    }
  }

  // Auto-hide loading después de 5 segundos como fallback
  setTimeout(() => {
    hidePdfLoading()
  }, 5000)

  // Detectar cambios en pantalla completa
  document.addEventListener('fullscreenchange', () => {
    const iframe = document.getElementById('pdf-iframe')
    if (document.fullscreenElement) {
      iframe.style.height = '100vh'
    } else {
      iframe.style.height = '82vh'
    }
  })
</script>

<style>
  /* Mejoras en el iframe */
  #pdf-iframe {
    border: none;
    background: #f9fafb;
  }

  /* Animaciones personalizadas */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out;
  }

  /* Mejoras en botones */
  button:focus,
  a:focus {
    outline: 2px solid #5e5884;
    outline-offset: 2px;
  }

  /* Loading spinner mejorado */
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .animate-spin {
    animation: spin 1s linear infinite;
  }

  /* Responsive improvements */
  @media (max-width: 768px) {
    #pdf-iframe {
      height: 72vh;
      min-height: 430px;
    }

    #pdf-container.fullscreen #pdf-iframe {
      height: 100vh;
    }
  }
</style>
