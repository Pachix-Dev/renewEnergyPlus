              </div>
              <div class="text-sm md:text-base font-extrabold text-white leading-tight">11:00 - 18:00</div>
            </div>

            <div class="rounded-lg bg-white/15 border border-white/20 px-3 py-2">
              <div class="text-[11px] md:text-xs font-semibold text-white/85 uppercase leading-tight">
                {i18next.language === "es" ? "Jueves 16 de abril" : "Thursday April 16"}
              </div>
              <div class="text-sm md:text-base font-extrabold text-white leading-tight">11:00 - 17:00</div>
            </div>
          </div>
        </div>
        <p class="text-white">
          {t("home.organized_by")}
        </p>
        <img
          src="/img/logosOrganizado.webp"
          alt="Italian German Exhibition Company Mexico"
          class="mt-3 w-[280px] md:w-[240px] lg:w-[340px] mx-auto md:mx-0"
