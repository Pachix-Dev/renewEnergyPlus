</section>
<style>
  .button {
    position: relative;
    transition: all 0.3s ease-in-out;
    box-shadow: 0px 10px 20px rgba(0, 0, 0, 0.2);
    padding-block: 1rem;
    padding-inline: 1.25rem;
    background: #4e549f;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    gap: 10px;
    border: 3px solid #ffffff4d;
    outline: none;
    overflow: hidden;
  }

  .button:hover {
    transform: scale(0.85);
    border-color: #fff9;
  }

  .button:hover .icon {
    transform: translate(4px);
  }

  .button:hover::before {
    animation: shine 1.5s ease-out infinite;
  }

  .button::before {
    content: "";
    position: absolute;
    width: 100px;
    height: 100%;
    background-image: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0) 30%,
      rgba(255, 255, 255, 0.8),
      rgba(255, 255, 255, 0) 70%
    );
    top: 0;
    left: -100px;
    opacity: 0.6;
  }

  p {
    text-shadow: 4px 4px 4px rgba(0, 0, 0, 0.8);
  }

  span {
    color: white;
    -webkit-text-stroke-width: 1px;
    -webkit-text-stroke-color: white;
  }
  .logoREPLUS {
    filter: drop-shadow(0px 0px 10px rgba(0, 0, 0, 0.8));
  }

  @keyframes shine {
    0% {
      left: -100px;
    }

    60% {
      left: 100%;
    }

    to {
      left: 100%;
    }
  }
  @keyframes border-glow-blue {
    0% {
      box-shadow:
        0 0 0 0 #38bdf8,
        0 0 0 0 #fff;
    }
    50% {
      box-shadow:
        0 0 24px 8px #38bdf8,
        0 0 12px 4px #fff;
    }
    100% {
      box-shadow:
        0 0 0 0 #38bdf8,
        0 0 0 0 #fff;
    }
  }
  @keyframes border-glow-yellow {
    0% {
      box-shadow:
        0 0 0 0 #fbbf24,
        0 0 0 0 #fff;
    }
    50% {
      box-shadow:
        0 0 24px 8px #fbbf24,
        0 0 12px 4px #fff;
    }
    100% {
      box-shadow:
        0 0 0 0 #fbbf24,
        0 0 0 0 #fff;
    }
  }

  /* Reset global span styles inside hero buttons */
  .hero-btn span {
    color: inherit;
    -webkit-text-stroke-width: 0;
    -webkit-text-stroke-color: transparent;
  }

  /* ── Hero buttons ───────────────────────── */
  .hero-btn {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1.1rem;
    border-radius: 1rem;
    border-left-width: 4px;
    border-left-style: solid;
    background: rgba(30,34,80,0.75);
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.35);
    text-decoration: none;
    transition: background 0.25s, box-shadow 0.3s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .hero-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.06), transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .hero-btn:hover::before { transform: translateX(100%); }
  .hero-btn:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.5); transform: translateY(-2px); }

  .hero-btn-blue   { border-left-color: #38bdf8; }
  .hero-btn-yellow { border-left-color: #fbbf24; }
  .hero-btn-purple { border-left-color: #a78bfa; }

  .hero-btn-blue:hover   { background: rgba(56,189,248,0.18); }
  .hero-btn-yellow:hover { background: rgba(251,191,36,0.15); }
  .hero-btn-purple:hover { background: rgba(167,139,250,0.18); }

  .hero-btn-icon {
    flex-shrink: 0;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-btn-icon-blue   { background: rgba(56,189,248,0.2);  color: #38bdf8; }
  .hero-btn-icon-yellow { background: rgba(251,191,36,0.2);  color: #fbbf24; }
  .hero-btn-icon-purple { background: rgba(167,139,250,0.2); color: #a78bfa; }

  .hero-btn-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    min-width: 0;
  }
  .hero-btn-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 1px 7px;
    border-radius: 999px;
    line-height: 1.5;
    -webkit-text-stroke: 0;
  }
  .hero-btn-label-blue   { background: rgba(56,189,248,0.2);  color: #7dd3fc !important; }
  .hero-btn-label-yellow { background: rgba(251,191,36,0.2);  color: #fde68a !important; }
  .hero-btn-label-purple { background: rgba(167,139,250,0.2); color: #c4b5fd !important; }

  .hero-btn-title {
    color: #fff !important;
    font-weight: 800;
    font-size: clamp(0.85rem, 2.5vw, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    -webkit-text-stroke: 0;
  }

  .hero-btn-arrow {
    flex-shrink: 0;
    color: rgba(255,255,255,0.6);
    transition: transform 0.25s, color 0.2s;
  }
  .hero-btn:hover .hero-btn-arrow { transform: translateX(4px); color: #fff; }

  /* Register info card shimmer */
  .hero-register-shimmer {
    background: linear-gradient(120deg, transparent 30%, rgba(251,191,36,0.08), transparent 70%);
    background-size: 200% 100%;
    animation: register-shimmer 3s ease-in-out infinite;
  }
  @keyframes register-shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }</style>
