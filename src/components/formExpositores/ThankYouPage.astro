---
import { Redirect } from "../../components/formExpositores/Redirect";
import i18next, { t } from "i18next";

const homeUrl = i18next.language === "en" ? "/en/" : "/";
const socialLinks = [
  {
    href: "https://www.facebook.com/REPlusMexico",
    label: "Facebook",
    path:
      "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z",
  },
  {
    href: "https://www.linkedin.com/company/replusmexico/",
    label: "LinkedIn",
    path:
      "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
  {
    href: "https://www.instagram.com/replusmexico/",
    label: "Instagram",
    path:
      "M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.795.645-1.44 1.44-1.44.794 0 1.44.646 1.44 1.44z",
  },
  {
    href: "https://www.youtube.com/@REplusmexico",
    label: "YouTube",
    path:
      "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
];
---

<section class="relative min-h-[100svh] overflow-hidden bg-[linear-gradient(180deg,#f8fafc_0%,#eef2ff_48%,#ffffff_100%)] text-slate-950 my-10">
  <Redirect client:only="react" />

  <div class="relative z-10 mx-auto grid min-h-[80svh] w-full max-w-7xl items-start gap-6 px-4 sm:px-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)] lg:items-center lg:gap-8 lg:px-10">
    <article
      aria-labelledby="thank-title"
      class="relative overflow-hidden rounded-lg bg-[#3333ff] p-6 text-white shadow-[0_24px_70px_rgba(51,51,255,0.22)] sm:p-8 lg:p-10"
    >
      <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#18188d] to-transparent"></div>
      <div class="relative">
        <div class="mt-6 max-w-2xl sm:mt-10 lg:mt-16">
          <p class="mb-4 inline-flex rounded-full border border-white bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-white">
            RE+ MEXICO 2027
          </p>
          <h1
            id="thank-title"
            class="text-[clamp(1.9rem,8.5vw,3rem)] font-black uppercase leading-[0.96] text-white break-words"
          >
            {t("thankYouPage.title")}
          </h1>

          <p class="mt-5 max-w-xl text-base leading-7 text-white/90 sm:text-lg sm:leading-8">
            {t("thankYouPage.description")}
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
            <a
              href={homeUrl}
              class="group inline-flex min-h-12 w-full items-center justify-center gap-3 rounded-full bg-white px-5 py-3 text-center text-sm font-extrabold leading-tight text-[#3333ff] no-underline shadow-lg shadow-[#18188d]/20 transition duration-200 hover:-translate-y-0.5 hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white sm:w-auto sm:px-6 sm:text-base"
            >
              <svg
                class="h-5 w-5 shrink-0 fill-current transition duration-200 group-hover:-translate-x-0.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M10.8 19.2 3.6 12l7.2-7.2 1.7 1.7L8.2 10.8h12.2v2.4H8.2l4.3 4.3-1.7 1.7Z"></path>
              </svg>
              <span>{t("thankYouPage.back_home")}</span>
            </a>
          </div>
        </div>
      </div>
    </article>

    <aside class="rounded-lg border border-slate-200 bg-white p-5 shadow-[0_18px_50px_rgba(15,23,42,0.1)] sm:p-6 lg:p-8">
      <div class="flex items-center gap-4 border-b border-slate-200 pb-5">
        <span aria-hidden="true" class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#3333ff] text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 14 14"><path fill="currentColor" fill-rule="evenodd" d="M7.933.767a.75.75 0 0 0-1.5 0v.754a.75.75 0 0 0 1.5 0zM6.595 2.928a.75.75 0 0 1 1.024.275l3.858 6.681a.75.75 0 0 1-1.299.75l-.055-.096l-3.092.718a2.171 2.171 0 0 1-3.97 1.664l-.002-.003l-.376-.651l-1.454.337a.5.5 0 0 1-.546-.237l-.609-1.055a.5.5 0 0 1 .068-.591l6.235-6.67l-.057-.097a.75.75 0 0 1 .275-1.025M4.21 11.911l1.357-.315a.671.671 0 0 1-1.21.57zm9.78-5.088a.75.75 0 0 1-.75.75h-.754a.75.75 0 0 1 0-1.5h.753a.75.75 0 0 1 .75.75Zm-12.108.75a.75.75 0 1 0 0-1.5h-.754a.75.75 0 1 0 0 1.5zm2.182-3.868a.75.75 0 0 1-1.06 0l-.634-.634a.75.75 0 1 1 1.06-1.06l.635.633a.75.75 0 0 1 0 1.061Zm7.932-.634a.75.75 0 0 0-1.06-1.06l-.642.64a.75.75 0 1 0 1.061 1.061z" clip-rule="evenodd"/></svg>
        </span>
        <div>
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[#3333ff]">{t("thankYouPage.textSocial")}</p>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-2 gap-3">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noreferrer"
            aria-label={social.label}
            class="group flex min-h-20 items-center  gap-2 sm:gap-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-4 text-sm font-bold text-slate-800 transition duration-200 hover:-translate-y-0.5 hover:border-[#3333ff]/40 hover:bg-white hover:text-[#3333ff] hover:shadow-lg hover:shadow-[#3333ff]/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#3333ff]"
          >
            <span class="inline-flex h-8 w-8 sm:h-16 sm:w-16 shrink-0 items-center justify-center rounded-full bg-white text-[#3333ff] ring-1 ring-slate-200 transition duration-200 group-hover:bg-[#3333ff] group-hover:text-white group-hover:ring-[#3333ff]">
              <svg class="h-5 w-5 sm:h-10 sm:w-10 fill-current" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d={social.path}></path>
              </svg>
            </span>
            <span>{social.label}</span>
          </a>
        ))}
      </div>
    </aside>
  </div>
</section>
