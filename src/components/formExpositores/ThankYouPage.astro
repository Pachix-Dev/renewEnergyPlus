---
import { Redirect } from "../../components/formExpositores/Redirect";
import i18next, { t } from "i18next";

const homeUrl = i18next.language === "en" ? "/en/" : "/";
const socialLinks = [
  {
    href: "https://www.facebook.com/EcomondoMexico",
    label: "Facebook",
    path:
      "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z",
  },
  {
    href: "https://www.linkedin.com/company/ecomondo-m%C3%A9xico/",
    label: "LinkedIn",
    path:
      "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
  {
    href: "https://www.instagram.com/ecomondomx?igsh=YzljYTk1ODg3Zg==",
    label: "Instagram",
    path:
      "M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.795.645-1.44 1.44-1.44.794 0 1.44.646 1.44 1.44z",
  },
  {
    href: "https://www.youtube.com/@EcomondoMEXICO",
    label: "YouTube",
    path:
      "M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z",
  },
];
---

<section class="relative min-h-[100svh] overflow-hidden bg-[#07100e] text-white">
  <Redirect client:only="react" />

  <div
    aria-hidden="true"
    class="absolute inset-0"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(0,208,132,0.16),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(168,244,207,0.1),transparent_24%)]"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-b from-[#061310]/88 via-[#061310]/74 to-[#061310]/92"
  >
  </div>

  <div class="relative z-10 mx-auto flex min-h-[100svh] w-full max-w-7xl items-end px-4 pb-10 pt-24 sm:px-6 sm:pb-14 lg:items-center lg:px-10 lg:py-28">
    <article
      aria-labelledby="thank-title"
      class="relative w-full overflow-hidden rounded-[28px] border border-white/15 bg-white/8 p-5 shadow-[0_24px_120px_rgba(0,0,0,0.42)] backdrop-blur-xl sm:p-8 lg:p-10"
    >
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(300px,0.85fr)] lg:items-end">
        <div class="relative overflow-hidden rounded-[24px] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.12),rgba(255,255,255,0.05))] p-5 sm:p-7 lg:p-8">
          <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#a8f4cf] to-transparent"></div>
          <div class="mb-5 inline-flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.24em] text-[#a8f4cf] sm:mb-6 sm:text-sm">
            <span
              aria-hidden="true"
              class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#00d084] text-[#083126] shadow-[0_0_0_7px_rgba(0,208,132,0.18)] sm:h-11 sm:w-11"
            >
              <svg class="h-6 w-6 fill-current" viewBox="0 0 24 24" focusable="false">
                <path d="M9.2 16.8 4.9 12.5l1.7-1.7 2.6 2.6 8.2-8.2 1.7 1.7-9.9 9.9Z"></path>
              </svg>
            </span>
            <span>ECOMONDO MEXICO</span>
          </div>

          <h1
            id="thank-title"
            class="max-w-[11ch] text-4xl font-black leading-[0.94] tracking-[-0.04em] text-white sm:text-5xl md:text-6xl lg:text-7xl"
          >
            {t("thankYouPage.title")}
          </h1>

          <p class="mt-5 max-w-2xl text-base leading-7 text-white/86 sm:text-lg sm:leading-8">
            {t("thankYouPage.description")}
          </p>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
            <a
              href={homeUrl}
              class="group inline-flex min-h-12 w-full items-center justify-center gap-3 rounded-full border border-[#a8f4cf]/25 bg-[#00d084] px-5 py-3 text-center text-sm font-extrabold leading-tight text-[#063126] no-underline transition duration-200 hover:-translate-y-0.5 hover:border-[#a8f4cf]/50 hover:bg-[#a8f4cf] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#a8f4cf] sm:w-auto sm:px-6 sm:text-base"
            >
              <svg
                class="h-5 w-5 shrink-0 fill-current transition duration-200 group-hover:-translate-x-0.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M10.8 19.2 3.6 12l7.2-7.2 1.7 1.7L8.2 10.8h12.2v2.4H8.2l4.3 4.3-1.7 1.7Z"></path>
              </svg>
              <span>{t("thankYouPage.back_home")}</span>
            </a>
          </div>
        </div>

        <aside class="rounded-[24px] border border-white/12 bg-[#081815]/80 p-5 shadow-[0_18px_80px_rgba(0,0,0,0.28)] sm:p-6">
          <div class="flex items-center gap-3 border-b border-white/10 pb-4">
            <span aria-hidden="true" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-white/10 text-[#a8f4cf]">
              <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" focusable="false">
                <path d="M12 22c-1.1 0-2-.9-2-2h4c0 1.1-.9 2-2 2Zm7-5H5v-2l1-1v-5c0-3.07 1.64-5.64 4.5-6.32V2.5h3V2.68C16.36 3.36 18 5.93 18 9v5l1 1v2Z"></path>
              </svg>
            </span>
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#a8f4cf]">{t("thankYouPage.textSocial")}</p>
            </div>
          </div>

          <div class="mt-5 grid grid-cols-2 gap-3">
            {socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noreferrer"
                aria-label={social.label}
                class="group flex flex-col items-center justify-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-center text-sm font-semibold text-white/90 transition duration-200 hover:-translate-y-0.5 hover:border-[#a8f4cf]/35 hover:bg-white/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#a8f4cf]"
              >
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white transition duration-200 group-hover:bg-[#00d084] group-hover:text-[#063126]">
                  <svg class="h-5 w-5 fill-current" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d={social.path}></path>
                  </svg>
                </span>
                <span>{social.label}</span>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </article>
  </div>
</section>
