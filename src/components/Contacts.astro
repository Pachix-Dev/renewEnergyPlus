---
import i18next, { t } from 'i18next'
const currentLanguage = i18next.language;

const nationalAgents = [
  {
    name: 'Yanelly Zuñiga',
    region: 'México',
    email: 'yanelly.zuniga@Igeco.mx',
    photo: '/img/yanelly_zuniga.webp',
    position : 'Sales Manager'
  },
  {
    name: 'Claudio Salinas',
    region: 'México',
    email: 'claudio.salinas@Igeco.mx',
    photo: '/img/claudio_salinas.webp',
    position : 'Sales Manager'
  },
]

const agents = [
  {
    name: 'Samuel Ramírez',
    region: 'México, Canada, Centro & Sudamérica',
    email: 'samuel.ramirez@igeco.mx',
    photo: '/img/samuel-ramirez.webp',
    position : ''
  },
  {
    name: 'Rayman Wu',
    region: 'China',
    email: 'info@snec.org.cn',
    photo: '/img/raymanWu.webp',
    position : 'Gerente de Ventas'
  },
  {
    name: 'Pamela Velazco',
    region: 'USA',
    email: 'pvelazco@re-plus.com',
    photo: '/img/Pamela-velazquez.webp',
  },
]
---
<section class='container mx-auto px-4 sm:px-6 md:px-10 lg:px-12'>
  <div class='mx-auto max-w-6xl'>
    <header class='text-center'>
      <h2 class='font-montserrat text-white text-3xl md:text-4xl font-semibold uppercase tracking-[0.2em]'>
        {t('footer.contact')}
      </h2>
      <p class='mt-3 text-white/70 text-sm md:text-base'>
        {currentLanguage === 'es' ? 'Conecta con nuestro equipo comercial según tu región.' : 'Connect with our sales team according to your region.'}
      </p>
    </header>

    <div class='mt-10'>
      <h3 class='text-white/80 text-base md:text-lg font-semibold uppercase tracking-[0.16em] text-center'>
        {currentLanguage === 'es' ? 'Contactos nacionales' : 'National contacts'}
      </h3>

      <div class='mt-6 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5'>
        {nationalAgents.map((agent) => (
          <article class='group rounded-2xl border border-white/20 bg-white/5 p-5 sm:p-6 transition-colors duration-200 hover:bg-white/10 min-w-0'>
            <div class='flex items-center gap-4'>
              <div class='h-14 w-14 shrink-0 overflow-hidden rounded-full border border-white/30 bg-white/10'>
                {
                  agent.photo ? (
                    <img
                      src={agent.photo}
                      alt={agent.name}
                      class='h-full w-full object-cover'
                    />
                  ) : (
                    <span class='flex h-full w-full items-center justify-center text-white text-sm font-semibold'>
                      CN
                    </span>
                  )
                }
              </div>

              <div class='min-w-0'>
                <p class='text-white text-lg font-semibold leading-tight'>
                  {agent.name}
                </p>
                <p class='mt-1 text-white/70 text-sm'>
                  {agent.position}
                </p>
                <p class='mt-1 text-white/70 text-sm'>
                  {agent.region}
                </p>
              </div>
            </div>

            <a
              href={`mailto:${agent.email}`}
              class='mt-5 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/25 px-4 py-2.5 text-white text-sm transition-colors duration-200 hover:bg-white hover:text-slate-900'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.8'
                class='h-4 w-4 shrink-0'
              >
                <path stroke-linecap='round' stroke-linejoin='round' d='M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75' />
              </svg>
              <span class='truncate'>
                {agent.email}
              </span>
            </a>
          </article>
        ))}
      </div>
    </div>

    <div class='mt-12'>
      <h3 class='text-white/80 text-base md:text-lg font-semibold uppercase tracking-[0.16em] text-center'>
        {currentLanguage === 'es' ? 'Contactos internacionales' : 'International contacts'}
      </h3>

      <div class='mt-6 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-5'>
        {agents.map((agent) => (
          <article class='group rounded-2xl border border-white/20 bg-white/5 p-5 sm:p-6 transition-colors duration-200 hover:bg-white/10 min-w-0'>
            <div class='flex items-center gap-4'>
              <div class='h-14 w-14 shrink-0 overflow-hidden rounded-full border border-white/30 bg-white/10'>
                <img
                  src={agent.photo}
                  alt={agent.name}
                  class='h-full w-full object-cover'
                />
              </div>

              <div class='min-w-0'>
                <p class='text-white text-lg font-semibold leading-tight'>
                  {agent.name}
                </p>
                <p class='mt-1 text-white/70 text-sm'>
                  {agent.region}
                </p>
              </div>
            </div>

            <a
              href={`mailto:${agent.email}`}
              class='mt-5 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/25 px-4 py-2.5 text-white text-sm transition-colors duration-200 hover:bg-white hover:text-slate-900'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='1.8'
                class='h-4 w-4 shrink-0'
              >
                <path stroke-linecap='round' stroke-linejoin='round' d='M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75' />
              </svg>
              <span class='truncate'>
                {agent.email}
              </span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
