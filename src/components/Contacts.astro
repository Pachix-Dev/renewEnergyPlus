---
import i18next, { t } from "i18next";
const currentLanguage = i18next.language;
const isSpanish = currentLanguage === "es";

const nationalAgents = [
  {
    name: "Yanelly Zuñiga",
    region: "México",
    email: "yanelly.zuniga@Igeco.mx",
    photo: "/img/yanelly_zuniga.webp",
    position: "Sales Manager",
  },
  {
    name: "Claudio Salinas",
    region: "México",
    email: "claudio.salinas@Igeco.mx",
    photo: "/img/claudio_salinas.webp",
    position: "Sales Manager",
  },
];

const internationalAgents = [
  {
    name: "Samuel Ramírez",
    region: "México, Canada, Centro & Sudamérica",
    email: "samuel.ramirez@igeco.mx",
    photo: "/img/samuel-ramirez.webp",
    position: "",
  },
  {
    name: "Rayman Wu",
    region: "China",
    email: "info@snec.org.cn",
    photo: "/img/raymanWu.webp",
    position: "Gerente de Ventas",
  },
  {
    name: "Pamela Velazco",
    region: "USA",
    email: "pvelazco@re-plus.com",
    photo: "/img/Pamela-velazquez.webp",
  },
];

const contactGroups = [
  {
    title: isSpanish ? "Contactos Nacionales" : "National Contacts",
    description: isSpanish
      ? "Cobertura comercial en todo México"
      : "Sales coverage across Mexico",
    agents: nationalAgents,
  },
  {
    title: isSpanish ? "Contactos Internacionales" : "International Contacts",
    description: isSpanish
      ? "Atención para mercados internacionales"
      : "Support for international markets",
    agents: internationalAgents,
  },
];
---

<section
  class="relative overflow-hidden bg-[url('/img/imagen2027/bg_contacto_ed2026.jpg')] bg-cover bg-center py-16 md:py-20"
>
  <div class="absolute inset-0 bg-slate-950/5"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="text-center">
      <h2
        class="font-montserrat text-white text-3xl md:text-4xl font-semibold uppercase tracking-[0.2em]"
      >
        {t("footer.contact")}
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-white text-sm md:text-base">
        {
          isSpanish
            ? "Conecta con nuestro equipo comercial según tu región."
            : "Connect with our sales team according to your region."
        }
      </p>
    </header>

    <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-3 lg:items-start">
      <div class="grid grid-cols-1 gap-6 lg:col-span-2 sm:grid-cols-2">
        {
          contactGroups.map((group) => (
            <article class="sm:p-6">
              <h3 class="text-white text-base md:text-lg font-semibold uppercase tracking-[0.14em] whitespace-pre-line sm:max-w-min">
                {group.title}
              </h3>
              <p class="mt-2 text-white/70 text-sm">{group.description}</p>

              <div class="mt-5 grid grid-cols-1 gap-4">
                {
                  group.agents.map((agent) => (
                    <article class="rounded-2xl border border-white/20 bg-white/5 p-4 transition-colors duration-200 hover:bg-white/10">
                      <div class="flex items-start gap-3">
                        <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full border border-white/25 bg-white/10">
                          <img
                            src={agent.photo}
                            alt={agent.name}
                            class="h-full w-full object-cover"
                          />
                        </div>

                        <div class="min-w-0 flex-1">
                          <p class="text-white text-lg font-semibold leading-tight">
                            {agent.name}
                          </p>
                          {
                            agent.position && (
                              <p class="mt-1 text-white/80 text-sm">{agent.position}</p>
                            )
                          }
                          <p class="mt-1 text-white/70 text-sm">{agent.region}</p>
                        </div>
                      </div>

                      <a
                        href={`mailto:${agent.email}`}
                        class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/25 px-4 py-2.5 text-white text-sm transition-colors duration-200 hover:bg-white hover:text-slate-900"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.8"
                          class="h-4 w-4 shrink-0"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                          />
                        </svg>
                        <span class="truncate">{agent.email}</span>
                      </a>
                    </article>
                  ))
                }
              </div>
            </article>
          ))
        }
      </div>
      <div class="">
        <img
          src="/img/imagen2027/replus_logo_ed2027.webp"
          alt="Replus mexico 2027 logo"
          class="mx-auto w-60 sm:w-full max-w-[360px] drop-shadow-2xl"
        />
      </div>
    </div>
  </div>
</section>
