---
import i18next, { t } from 'i18next';

interface Props {
  base?: string;
}

const { base = "" } = Astro.props;

const products = [
  {
    id: 1,
    name: 'PREMIUM PASS',
    name_en: 'PREMIUM PASS',
    subtitle: 'La experiencia completa',
    subtitle_en: 'The complete experience',
    price: 7500, // Precio unitario - Última fase
    originalPrice: 7500,
    popular: true,
    included: [
      '3 Días de conferencias (14, 15 y 16 abril 2026)',
      '1 Pase para Energy Night (martes 14 de abril)',
      'Acceso a la VIP AREA',
      'Sunset Cocktail (miércoles 15 de abril)',
    ],
    included_en: [
      '3 days of conferences (April 14, 15 and 16, 2026)',
      '1 Pass for Energy Night (Tuesday, April 14)',
      'Access to the VIP AREA',
      'Sunset Cocktail on Wednesday, April 15',
    ],
    icon: '❇️',
    gradient: 'from-yellow-400 via-amber-500 to-orange-500',
    bgGradient: 'from-yellow-50 to-amber-50',
    borderColor: 'border-yellow-300',
    textColor: 'text-yellow-600',
  },
  {
    id: 2,
    name: 'ENERGY NIGHT',
    name_en: 'ENERGY NIGHT',
    subtitle: 'La noche más esperada',
    subtitle_en: 'The most anticipated night',
    price: 1200, // Precio unitario - Última fase
    originalPrice: 1200,
    popular: false,
    included: [
      'Entrada con bebidas ilimitadas y snacks',
      'Acceso martes 14 de abril',
      'Lugar: Desfilia, Expo Guadalajara',
      'Duración: 6:30 p.m. - 10:00 p.m.',
    ],
    included_en: [
      'Entry with unlimited drinks and snacks',
      'Access Tuesday, April 14',
      'Location: Desfilia, Expo Guadalajara',
      'Duration: 6:30 p.m. - 10:00 p.m.',
    ],
    icon: '🌙',
    gradient: 'from-purple-500 via-violet-500 to-indigo-600',
    bgGradient: 'from-purple-50 to-violet-50',
    borderColor: 'border-purple-300',
    textColor: 'text-purple-600',
  },
  {
    id: 3,
    name: 'DAY PASS',
    name_en: 'DAY PASS',
    subtitle: 'Acceso por un día',
    subtitle_en: 'One day access',
    price: 2600, // Precio unitario - Última fase
    originalPrice: 2600,
    popular: false,
    included: [
      'Acceso a conferencias premium por un día',
      'Válido para el día que elijas',
      'Incluye Coffee Break',
      'Elige: 14, 15 o 16 de abril',
    ],
    included_en: [
      'Premium conference access for one day',
      'Valid for the day you choose',
      'Includes Coffee Break',
      'Choose: April 14, 15 or 16',
    ],
    icon: '📅',
    gradient: 'from-cyan-500 via-blue-500 to-indigo-500',
    bgGradient: 'from-cyan-50 to-blue-50',
    borderColor: 'border-cyan-300',
    textColor: 'text-cyan-600',
  },
];

const lang = i18next.language;
---

<section class="productos-premium-preview py-16 px-4 bg-[url(/img/background_keynotesSpek.webp)] bg-cover bg-center p-10">
  <div class="container mx-auto max-w-7xl">
    
    <!-- Header -->
    <div class="text-center mb-12" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4">
        {lang === 'es' ? 'Conoce los diferentes accesos' : 'Discover the different access options'}
      </h2>
      <p class="text-white text-lg max-w-2xl mx-auto">
        {lang === 'es' 
          ? '¡Aprovecha las promociones de preventa y asegura tu lugar hoy mismo!'
          : 'Take advantage of the pre-sale promotions and secure your spot today!'}
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {products.map((product, index) => (
        <article 
          class={`producto-card group relative rounded-3xl overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:-translate-y-2 ${product.popular ? 'lg:scale-105 lg:z-10' : ''}`}
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          {/* Badge popular */}
          {product.popular && (
            <div class="absolute -top-1 left-1/2 transform -translate-x-1/2 z-20">
              <div class="bg-gradient-to-r from-yellow-400 to-orange-500 text-white text-xs font-bold uppercase px-4 py-1.5 rounded-full shadow-lg flex items-center gap-1">
                <span>🔥</span>
                <span>{lang === 'es' ? 'Más popular' : 'Most popular'}</span>
              </div>
            </div>
          )}

          {/* Card container */}
          <div class={`relative h-full bg-white/95 backdrop-blur-sm border-2 rounded-3xl overflow-hidden flex flex-col ${product.popular ? 'border-yellow-400 shadow-2xl shadow-yellow-400/20' : 'border-white/20 shadow-xl'}`}>
            
            {/* Header con gradiente */}
            <div class={`relative bg-gradient-to-br ${product.gradient} px-6 py-8 text-center overflow-hidden`}>
              {/* Elementos decorativos */}   
              <div class="absolute inset-0 opacity-20">
                <div class="absolute -top-4 -right-4 w-24 h-24 border-4 border-white rounded-full"></div>
                <div class="absolute -bottom-6 -left-6 w-32 h-32 border-2 border-white rounded-full"></div>
              </div>
              
              <div class="relative z-10">
                <span class="text-4xl mb-3 block z">{product.icon}</span>
                <h3 class="text-xl lg:text-2xl font-black text-white mb-1">
                  {lang === 'es' ? product.name : product.name_en}
                </h3>
                <p class="text-white/90 text-sm font-medium">
                  {lang === 'es' ? product.subtitle : product.subtitle_en}
                </p>
              </div>
            </div>

            {/* Precio */}
            <div class={`px-6 py-5 bg-gradient-to-r ${product.bgGradient} border-b ${product.borderColor}`}>
              <div class="flex items-center justify-center gap-3">
                <div class="text-center">
                  <div class="flex items-baseline justify-center">
                    <span class="text-lg font-semibold text-gray-500">$</span>
                    <span class={`text-4xl lg:text-5xl font-black ${product.textColor}`}>
                      {product.price.toLocaleString('es-MX')}
                    </span>
                    <span class="text-sm font-medium text-gray-500 ml-1">MXN</span>
                  </div>
                  {/* <div class="flex items-center justify-center gap-2 mt-1">
                    <span class="text-sm text-gray-400 line-through">
                      ${product.originalPrice.toLocaleString('es-MX')}
                    </span>
                    <span class="bg-green-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">
                      {lang === 'es' ? 'FASE 1' : 'PHASE 1'}
                    </span>
                  </div> */}
                </div>
              </div>
            </div>

            {/* Lista de beneficios */}
            <div class="flex-1 px-6 py-6">
              <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-4">
                {lang === 'es' ? 'Incluye:' : 'Includes:'}
              </p>
              <ul class="space-y-3">
                {(lang === 'es' ? product.included : product.included_en).map((item) => (
                  <li class="flex items-start gap-3">
                    <div class={`flex-shrink-0 w-5 h-5 rounded-full bg-gradient-to-br ${product.gradient} flex items-center justify-center mt-0.5`}>
                      <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                    </div>
                    <span class="text-gray-700 text-sm font-medium leading-snug">{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Footer con CTA */}
            <div class="px-6 pb-6">
              <a 
                href={`${base}/programa-premium-productos`}
                class={`w-full flex items-center justify-center gap-2 py-4 px-6 rounded-xl font-bold text-white bg-gradient-to-r ${product.gradient} hover:opacity-90 transition-all duration-300 shadow-lg hover:shadow-xl group-hover:gap-3`}
              >
                <span>{lang === 'es' ? 'Comprar ahora' : 'Buy now'}</span>
                <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </a>
            </div>

          </div>
        </article>
      ))}
    </div>

    {/* Boton de venta de pases premium */}
    <!-- <div class="flex justify-center mt-14">
          <a
            href={`${base}/programa-premium-productos`}
            class="inline-flex items-center gap-4 px-8 sm:px-12 py-5 sm:text-2xl font-extrabold rounded-full shadow-xl border-4 border-yellow-400 bg-gradient-to-r from-yellow-400 via-[#5E5884] to-[#1E293B] text-white tracking-wider transition-all duration-300 hover:scale-105 hover:shadow-yellow-400/40 focus:outline-none focus:ring-4 focus:ring-yellow-300/40"
          >
            <span class="uppercase tracking-wider drop-shadow-lg"
              >{t("program.button2")}</span
            >
            <svg
              version="1.1"
              id="Uploaded to svgrepo.com"
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              width="26px"
              height="26px"
              viewBox="0 0 32 32"
              xml:space="preserve"
              fill="#000000"
              ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
                id="SVGRepo_tracerCarrier"
                stroke-linecap="round"
                stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
                <style type="text/css">
                  .puchipuchi_een {
                    fill: #ffffff;
                  }
                </style>
                <path
                  class="puchipuchi_een"
                  d="M20.414,26.414l9-9c0.781-0.781,0.781-2.047,0-2.828l-9-9c-0.781-0.781-2.047-0.781-2.828,0 s-0.781,2.047,0,2.828L23.172,14H4c-1.104,0-2,0.896-2,2s0.896,2,2,2h19.172l-5.586,5.586c-0.781,0.781-0.781,2.047,0,2.828 S19.633,27.195,20.414,26.414z"
                ></path>
              </g></svg
            >
          </a>
    </div> -->

    </div>
</section>

<style>
  .producto-card {
    perspective: 1000px;
  }

  .producto-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 1;
    border-radius: 1.5rem;
  }

  
</style>
