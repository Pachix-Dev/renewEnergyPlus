---
import i18next, { t } from "i18next";

interface Props {
  base?: string;
}

const { base = "" } = Astro.props;
---

<!-- SECCIÓN SOBRE LA EXPERIENCIA PREMIUM -->
<div class="relative min-h-screen  bg-gradient-to-br from-gray-900 via-gray-800 to-black overflow-hidden">

  <!-- Contenido principal -->
  <div class="relative z-10 min-h-screen flex flex-col">
    <!-- Header Section -->
    <div
      class="container mx-auto px-4 py-10 flex-1 flex flex-col justify-center"
    >
      <!-- Main Title -->
      <div
        class="text-center"
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="200"
      >
        <h1
          class="text-5xl sm:text-6xl lg:text-7xl font-black text-white mb-6 leading-tight"
          data-aos="zoom-in"
          data-aos-duration="1200"
          data-aos-delay="100"
        >
          {t("program.title_content_premium")}
        </h1>

        <!-- Tarjetas de contenido experiencia premium -->
        <div
          class="mt-12 grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto"
        >
          <!-- Tarjeta: Conferencias Premium -->
          <a
            href={
              `${base}/programa-premium`
