<style>
  /* Mejoras en las sombras de texto */
  h1 {
    text-shadow: 2px 2px 12px rgba(0, 0, 0, 0.8);
  }

  .premium-card-v2 {
    background: linear-gradient(
      135deg,
      #1e293bcc 0%,
      #5e588499 60%,
      #1e293bcc 100%
    );
    border-radius: 1.25rem;
    border: 2px solid #5e5884;
    box-shadow:
      0 8px 32px 0 rgba(94, 88, 132, 0.18),
      0 0 24px 0 #5e5884aa;
    transition:
      box-shadow 0.4s,
      transform 0.4s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
  }
  .premium-card-v2:hover {
    box-shadow:
      0 20px 60px 0 #5e5884cc,
      0 0 32px 0 #1e293bcc;
    background: linear-gradient(
      135deg,
      #5e5884cc 0%,
      #1e293b99 60%,
      #1e293bcc 100%
    );
    transform: translateY(-8px) scale(1.04);
  }
  .premium-img-circle {
    box-shadow: 0 4px 24px 0 #5e5884aa;
    border-radius: 9999px;
    background: rgba(30, 41, 59, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      box-shadow 0.3s,
      border 0.3s;
  }
</style>
