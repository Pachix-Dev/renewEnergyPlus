                class="premium-img-circle bg-white/10 border-4 border-[#5E5884] rounded-full p-2 shadow-lg mt-6 z-10"
              >
                <div
                  class="relative w-[140px] h-[140px] sm:w-[180px] sm:h-[180px] md:w-[220px] md:h-[220px] lg:w-[260px] lg:h-[260px] flex items-center justify-center rounded-full bg-gradient-to-br from-[#5E5884]/80 via-[#1E293B]/60 to-[#5E5884]/40"
                >
                  <img
                    src="/img/conferencias_premium.webp"
