---
import i18next from "i18next";
const currentLanguage = i18next.language === "es";
const base = currentLanguage ? "" : `/${i18next.language}`;

const sectionCopy = {
  title: currentLanguage
    ? "Elige tu espacio en RE+ MEXICO 2027"
    : "Choose your space at RE+ MEXICO 2027",
  subtitle: currentLanguage ? "Tarifas de participación" : "Participation fee",
};

const stands = [
  {
    cardTitle: currentLanguage ? "STAND EQUIPADO" : "EQUIPPED STAND",
    cardTag: currentLanguage ? "a partir de 9 m2" : "from 9 sqm",
    includes: currentLanguage ? "Incluye" : "Includes",
    imageSrc: "/img/imagen2027/equipado_basico.png",
    imageAlt: currentLanguage ? "Stand equipado basico" : "Basic equipped stand",
    items: currentLanguage
      ? [
          "Alfombra estandar",
          "Mamparas divisorias",
          "Antepecho con rotulo de vinil",
          "Mobiliario estandar (counter, mesa y 2 sillas)",
          "1 contacto electrico de 110v",
          "Gafetes de expositor (3 por cada 9 m2)",
          "Código de pre-registro de visitantes ilimitados para su compañía",
          "Incluye mención en el directorio de expositores",
        ]
      : [
          "Standard carpeting",
          "Dividing partitions",
          "Counter with vinyl sign",
          "Standard furniture (counter, table and 2 chairs)",
          "One 110v electrical outlet",
          "Exhibitor badges (3 per each 9 sqm)",
          "Unlimited visitor pre-registration code for your company",
          "Includes mention in the exhibitor directory",
        ],
  },
  {
    cardTitle: currentLanguage ? "RAW SPACE" : "RAW SPACE",
    cardTag: currentLanguage ? "a partir de 18 m2" : "from 18 sqm",
    includes: currentLanguage ? "Incluye" : "Includes",
    imageSrc: "/img/imagen2027/raw_space_redner.png",
    imageAlt: currentLanguage ? "Stand en area libre" : "Raw space stand",
    items: currentLanguage
      ? [
          "Gafetes de expositor (3 por cada 9m2)",
          "Código de pre-registro de visitantes ilimitados para su compañía",
          "Mención en el directorio",
        ]
      : [
          "Exhibitor badges (3 per each 9 sqm)",
          "Unlimited visitor pre-registration code for your company",
          "Mention in the directory",
        ],
    warning: currentLanguage
      ? "El espacio raw space no incluye construcción de stand, mobiliario, ni servicios adicionales."
      : "The raw space does not include stand construction, furniture, or additional services.",
  },
];
---

<section class="tariff-section py-8 sm:py-16 md:py-10">
  <div class="mx-auto px-4">
    <header class="mx-auto mb-10 text-center md:mb-10">
      <p class="tariff-kicker">{sectionCopy.subtitle}</p>
      <h2 class="tariff-title font-extrabold mx-auto">{sectionCopy.title}</h2>
    </header>

    <div class="tariff-grid max-w-7xl mx-auto">
      {
        stands.map((stand) => (
          <article class="tariff-card">
            <div class="tariff-topbar">
              <h3>{stand.cardTitle}</h3>
              <span class="text-6xl">{stand.cardTag}</span>
            </div>

            <div class="tariff-body">
              <div class="tariff-image-panel">
                <img
                  src={stand.imageSrc}
                  alt={stand.imageAlt}
                  loading="lazy"
                  class="tariff-image"
                />
              </div>

              <div class="tariff-content">
                <div class="includes-box">
                  <p class="includes-title">{stand.includes}</p>
                  <ul class="includes-list">
                    {stand.items.map((item) => (
                      <li>
                        <span class="check" aria-hidden="true">
                          ✓
                        </span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="flex items-start gap-2 mt-4 sm:mt-10 font-semibold text-sm text-red-600">
                    {stand.warning && (
                      <>
                        <span class="warning-icon" aria-hidden="true">
                          !
                        </span>
                      </>
                    )}
                    <p>{stand.warning}</p>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div>
        <a href={`${base}/contacto`} class="">
          <img src={currentLanguage ? "/img/imagen2027/btn_cotizar.webp" : "/img/imagen2027/btn_cotizar_en.webp"} alt="Contact Icon" class="w-[600px] tariff-image mx-auto pt-12" />
        </a>
    </div>
  </div>
</section>

<style>
  .tariff-section {
    background: radial-gradient(
      circle at 20% 0%,
      #ffffff 0%,
      #f3f4f6 55%,
      #eceff3 100%
    );
  }

  .tariff-grid {
    display: grid;
    gap: 1.25rem;
  }

  .tariff-title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .tariff-kicker {
    color: #e91e8c;
    font-size: clamp(1rem, 2.2vw, 1.1rem);
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .tariff-card {
    border-radius: 1.25rem;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 24px 50px rgba(15, 23, 42, 0.14);
  }

  .tariff-topbar {
    background: linear-gradient(90deg, #0d53d3 0%, #3333ff 100%);
    color: #ffffff;
    text-align: center;
    padding: 1.3rem 1rem 1rem;
  }

  .tariff-topbar h3 {
    font-size: clamp(1.7rem, 4vw, 2.35rem);
    font-weight: 900;
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .tariff-topbar span {
    display: inline-block;
    margin-top: 0.55rem;
    font-size: clamp(1.5rem, 2vw, 1.5rem);
    font-weight: 600;
    opacity: 0.94;
  }

  .tariff-content {
    display: grid;
    gap: 1rem;
    align-content: center;
  }

  .tariff-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .tariff-image-panel {
    background: linear-gradient(145deg, #f9fbff 0%, #e6ebf6 100%);
    border: 1px solid #dbe1ec;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    min-height: 14rem;
  }

  .tariff-image {
    width: min(100%, 28rem);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 16px 18px rgba(15, 23, 42, 0.25));
  }

  .includes-box {
    background: #f7f8fb;
    border-radius: 1rem;
    padding: 1rem;
    border: 1px solid #e0e4ec;
  }

  .includes-title {
    color: #3333ff;
    text-transform: uppercase;
    font-size: 0.88rem;
    font-weight: 900;
    margin-bottom: 0.65rem;
  }

  .includes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .includes-list li {
    display: grid;
    grid-template-columns: 1.25rem 1fr;
    gap: 0.55rem;
    align-items: start;
    color: #111827;
    font-size: 0.96rem;
    line-height: 1.3;
    font-weight: 600;
  }

  .check {
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 999px;
    background: #3333ff;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 900;
    margin-top: 0.04rem;
  }


  .warning-icon {
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 999px;
    background: #e02424;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.74rem;
    font-weight: 900;
    flex-shrink: 0;
    margin-top: 0.09rem;
  }

  @media (min-width: 980px) {
    .tariff-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: stretch;
    }

    .tariff-body {
      grid-template-columns: minmax(260px, 42%) 1fr;
      gap: 1.5rem;
      padding: 1.5rem;
      align-items: stretch;
    }

    .tariff-image-panel {
      min-height: 100%;
      padding: 1.25rem;
    }

    .tariff-content {
      align-content: start;
    }
  }
</style>
