---
import { buyers } from "../data/constanst_buyers";
import i18next, { t } from "i18next";
---

<section class="py-16 bg-gradient-to-b from-white to-slate-50">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-12" data-aos="fade-up" data-aos-duration="800">
      <h2
        class="text-3xl sm:text-5xl text-[#565078] uppercase font-extrabold tracking-wide"
      >
        {
          i18next.language === "es"
            ? "Compradores Profesionales"
            : "Professional Buyers"
        }
      </h2>
    </div>

    <!-- Stat + cards -->
    <div
      class="flex flex-col lg:flex-row items-center justify-center gap-12 mb-16"
      data-aos="fade-up"
      data-aos-duration="1000"
    >
      <!-- Spinning ring stat -->
      <div class="relative flex items-center justify-center shrink-0">
        <div
          class="absolute h-[340px] w-[340px] rounded-full bg-gradient-to-br from-orange-300 via-purple-400 to-purple-700 opacity-20 blur-2xl"
        >
        </div>
        <div
          class="relative p-[5px] lg:animate-spin bg-gradient-to-bl from-orange-400 via-purple-400 to-purple-600 h-[300px] w-[300px] rounded-full shadow-xl"
        >
          <div class="rounded-full h-full w-full bg-white"></div>
        </div>
        <div class="absolute text-[#565078] text-center px-6">
          <p class="text-7xl font-black leading-none">
            +83<span class="text-4xl">%</span>
          </p>
          <p class="text-base font-bold mt-2 leading-snug">
            {
              i18next.language === "es"
                ? "de los visitantes son"
                : "of visitors are"
            }
            <br />
            <span class="text-orange-500">
              {
                i18next.language === "es"
                  ? "tomadores de decisión"
                  : "decision makers"
              }
            </span>
          </p>
        </div>
      </div>
    </div>

    <!-- Logo grid -->
    <div
      class="grid grid-cols-3 sm:grid-cols-5 md:grid-cols-8 gap-3 sm:gap-4"
      data-aos="fade-up"
      data-aos-duration="1200"
    >
      {
        buyers.map((buyer) => (
          <div class="group flex items-center justify-center bg-transparent rounded-xl border border-slate-100 shadow-sm p-3 hover:shadow-md hover:border-purple-200 transition-all duration-300">
            <img
              src={buyer.src}
              alt={buyer.alt}
              width={buyer.width}
              height={buyer.height}
              class="w-full h-auto max-h-[55px] object-contain transition-all duration-300"
            />
          </div>
        ))
      }
    </div>

    <!-- Footer note -->
    <p
      data-aos="fade-up"
      data-aos-duration="1000"
      class="text-base font-bold text-right bg-clip-text text-[#565078] mt-6 italic"
    >
      {t("home.entreotros")}
    </p>
  </div>
</section>
