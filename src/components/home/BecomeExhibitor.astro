---
import i18next, { t } from "i18next";
const currentLanguage = i18next.language;
const base = currentLanguage === "es" ? "" : `/${currentLanguage}`;
---
<section class="bg-gradient-to-r from-[#18188d] via-[#3333ff] to-[#3333ff] text-white text-center py-10 relative overflow-hidden sm:border-t-8 border-t-white">
  <div class="mx-auto px-4 relative z-10 flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10">
    <div
      class="flex flex-col justify-center items-center"
      data-aos="zoom-out-right"
      data-aos-duration="2000"
      data-aos-delay="300"
    >
      <h3 class="text-3xl sm:text-4xl lg:text-5xl">
        {currentLanguage === "es" ? "CONVIÉRTETE EN" : "BECOME AN"}
        <span class="font-extrabold">
          {currentLanguage === "es" ? "EXPOSITOR" : "EXHIBITOR"}
        </span>
      </h3>
    </div>
    <div class="flex flex-col items-center" 
      data-aos="zoom-out-right"
      data-aos-duration="2000"
      data-aos-delay="300"
      >
      <a href={`${base}/quiero-ser-expositor`}>
        <img
          src={currentLanguage === "es"
            ? "/img/imagen2027/btn_contact_es.webp"
            : "/img/imagen2027/btn_contact_en.webp"}
          alt="replus mexico 2027 contact"
          class="w-48 sm:w-56 md:w-64 lg:w-72 hover:scale-105 transition-transform duration-300 mx-auto mt-4 sm:mt-6"
        />
      </a>
      <a href={`${base}/plano-re-plus-mexico-2027`}>
        <img
          src="/img/imagen2027/btn_floorplant.webp"
          alt="replus mexico 2027 floor plant"
          class="w-48 sm:w-56 md:w-64 lg:w-72 hover:scale-105 transition-transform duration-300 mx-auto mt-4"
        />
      </a>
    </div>
  </div>
</section>
