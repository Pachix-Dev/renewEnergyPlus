---
import i18next, { t } from "i18next";
const base = i18next.language === "es" ? "" : `/${i18next.language}`;
const currentLanguage = i18next.language;

---
<section class="relative w-full overflow-hidden bg-black lg:min-h-screen">
  <img
    src="/img/imagen2027/background_hero_2027.webp"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover"
  />
  <div class="absolute inset-0 bg-black/20"></div>
  <div class="relative z-10 flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-10 text-white text-center px-4 sm:px-8 lg:px-16 xl:px-24 py-10 sm:py-12 lg:min-h-screen">
    <div class="hidden lg:flex justify-center w-full lg:w-2/5" data-aos="fade-up" data-aos-duration="1000">
      <img
        src="/img/imagen2027/replus_logo_2027.webp"
        alt="Replus Logo"
        class="w-full max-w-[220px] sm:max-w-[280px] md:max-w-[340px] lg:max-w-[420px] h-auto"
      />
    </div>
    <div class="flex flex-col justify-center items-center w-full lg:w-3/5 gap-3 sm:gap-2">
        <p class="text-center lg:text-left text-base sm:text-lg md:text-2xl lg:text-3xl font-anton">{currentLanguage === "es" ? "LA FERIA LÍDER EN ENERGÍAS RENOVABLES" : "THE LEADING FAIR IN RENEWABLE ENERGIES"}</p>
        <img src="/img/imagen2027/slogan.webp" alt="Slogan" class="w-full max-w-[320px] sm:max-w-[460px] md:max-w-[620px] lg:max-w-[860px] h-auto" />
        <div class="w-full flex justify-center">
          <img src="/img/imagen2027/date_event.webp" alt="Date Event" class="w-full max-w-[220px] sm:max-w-[320px] md:max-w-[420px] lg:max-w-[600px] h-auto mx-auto" />
        </div>
    </div>
  </div>
</section>
