---
import i18next from "i18next";
const currentLanguage = i18next.language;
---

<section
  class="rp-wrap"
  aria-label="Cifras destacadas RE+ Mexico 2027"
  itemscope
  itemtype="https://schema.org/Event"
>
  <meta itemprop="name" content="RE+ Mexico 2027" />
  <meta itemprop="location" content="Expo Guadalajara, Jalisco, México" />

  <header class="rp-header" data-aos="fade-up" data-aos-duration="900">
    <div class="rp-eyebrow" data-aos="fade-up" data-aos-duration="900" data-aos-delay="80">
      <span class="rp-eyebrow-text">RE+ Mexico 2027 · Expo Guadalajara</span>
    </div>
    <h2 class="rp-title" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="140">
      <span class="rp-title-dark">
        {
          currentLanguage === "es"
            ? "EL MERCADO DE ENERGÍAS RENOVABLES"
            : "THE LARGEST RENEWABLE ENERGY MARKET"
        }
      </span>
      <span class="rp-title-animated">
        {currentLanguage === "es" ? "MÁS GRANDE DE MÉXICO" : "IN MEXICO"}
      </span>
    </h2>
    <p class="rp-sub" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="220">
      {
        currentLanguage === "es"
          ? "Datos basados en la edición 2026"
          : "Data based on the 2026 edition"
      }
    </p>
  </header>
  <div>
    <div class="flex flex-col sm:flex-row gap-4 text-style">
      <div class="bg-[url(/img/imagen2027/highlight_01.webp)] rp-highlight-card w-full bg-cover bg-center flex items-center justify-center"
        data-aos="zoom-in-up"
        data-aos-duration="900"
        data-aos-delay="100"
      >
        <p class="text-white rp-highlight-copy text-center px-4 uppercase max-w-sm font-semibold">
          <span class="block rp-highlight-number font-extrabold">
             +12,500
          </span>
          {
            currentLanguage === "es"
              ? "compradores profesionales"
              : "professional buyers"
          }
        </p>
      </div>
      <div class="bg-[url(/img/imagen2027/highlight_02.webp)] rp-highlight-card w-full bg-cover bg-center flex items-center justify-center"
        data-aos="zoom-in-up"
        data-aos-duration="900"
        data-aos-delay="180"
      >
        <p class="text-white rp-highlight-copy text-center px-4 uppercase max-w-sm font-semibold">
          <span class="block rp-highlight-number font-extrabold">
             +10,000 m2
          </span>
          {
            currentLanguage === "es"
              ? "piso expositor"
              : "exhibition space"
          }
        </p>
      </div>
      <div class="bg-[url(/img/imagen2027/highlight_03.webp)] rp-highlight-card w-full bg-cover bg-center flex items-center justify-center"
        data-aos="zoom-in-up"
        data-aos-duration="900"
        data-aos-delay="260"
      >
        <p class="text-white rp-highlight-copy text-center px-4 uppercase max-w-sm font-semibold">
          <span class="block rp-highlight-number font-extrabold">
             80%
          </span>
          {
            currentLanguage === "es"
              ? "De los visitantes participan en el proceso de compra de sus empresas"
              : "Of visitors are involved in the purchasing process of their companies"
          }
        </p>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row gap-4 mt-4 text-style">
      <div
        class="bg-[url(/img/imagen2027/highlight_04.webp)] rp-highlight-card w-full bg-cover bg-center flex items-center justify-center"
        data-aos="zoom-in-up"
        data-aos-duration="900"
        data-aos-delay="340"
      >
        <p class="text-white rp-highlight-copy text-center px-4 uppercase max-w-sm font-semibold">
          <span class="block rp-highlight-number font-extrabold">
             76%
          </span>
          {
            currentLanguage === "es"
              ? "De los visitantes son directivos "
              : "Of visitors are executives"
          }
        </p>
      </div>
      <div
        class="bg-[url(/img/imagen2027/highlight_05.webp)] rp-highlight-card w-full bg-cover bg-center flex items-center justify-center"
        data-aos="zoom-in-up"
        data-aos-duration="900"
        data-aos-delay="420"
      >
        <p class="text-white rp-highlight-copy text-center px-4 uppercase max-w-sm font-semibold">
          <span class="block rp-highlight-number font-extrabold">
             +70
          </span>
          {
            currentLanguage === "es"
              ? "CONFERENCIAS DE ALTO NIVEL"
              : "LEADING CONFERENCES"
          }
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  @font-face {
    font-family: "Anton";
    src: url("/fonts/Anton-Regular.ttf") format("truetype");
    font-weight: 400;
    font-display: swap;
  }
  @font-face {
    font-family: "Montserrat";
    src: url("/fonts/Montserrat-VariableFont_wght.ttf") format("truetype");
    font-weight: 100 900;
    font-display: swap;
  }
  @font-face {
    font-family: "Montserrat";
    src: url("/fonts/Montserrat-Italic-VariableFont_wght.ttf")
      format("truetype");
    font-weight: 100 900;
    font-style: italic;
    font-display: swap;
  }

  @keyframes gradientFlow {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .rp-wrap {
    background: #f4f7f5;
    padding-bottom: clamp(48px, 7vw, 96px);
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  .rp-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 1.5rem 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .rp-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 1rem;
    width: 100%;
    flex-wrap: nowrap;
  }

  .rp-eyebrow-text {
    font-family: "Montserrat", sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #e91e8c;
    font-size: clamp(0.6rem, 2.2vw, 1.1rem);
    white-space: nowrap;
    flex-shrink: 1;
  }

  .rp-title {
    font-family: "Anton", sans-serif;
    font-size: clamp(2.4rem, 7vw, 4rem);
    line-height: 1.05;
    letter-spacing: 0.03em;
    margin: 0 0 0.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.05em;
    white-space: normal;
    word-break: break-word;
    overflow-wrap: break-word;
    width: 100%;
  }

  .rp-title-dark {
    color: #0d1a2e;
  }

  .rp-title-animated {
    background: linear-gradient(
      90deg,
      #0407cf 0%,
      #0f1cd6 25%,
      #277ff3 50%,
      #0257f5 75%,
      #0205ca 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientFlow 4s linear infinite;
  }

  .rp-sub {
    font-family: "Montserrat", sans-serif;
    font-weight: 600;
    font-style: italic;
    font-size: clamp(0.9rem, 1.6vw, 1.3rem);
    color: #555555;
    margin: 0;
    max-width: 90%;
    word-break: break-word;
  }

  .text-style {
    text-shadow: 2px 4px 10px rgba(0, 0, 0, 0.8);
  }

  .rp-highlight-card {
    height: 16rem;
  }

  .rp-highlight-copy {
    font-size: clamp(1rem, 1.8vw, 1.5rem);
  }

  .rp-highlight-number {
    font-size: clamp(2.4rem, 4.8vw, 3.75rem);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 640px) {
    .rp-header {
      padding: 2rem 1rem 1.25rem;
    }

    .rp-highlight-card {
      height: 11.5rem;
    }

    .rp-highlight-copy {
      font-size: 1.3rem;
      line-height: 1.2;
    }

    .rp-highlight-number {
      font-size: 3rem;
      margin-bottom: 0.35rem;
    }
  }
  
</style>
