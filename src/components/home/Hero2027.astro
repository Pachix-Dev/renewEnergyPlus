---
import i18next, { t } from "i18next";
const base = i18next.language === "es" ? "" : `/${i18next.language}`;
const currentLanguage = i18next.language;
---

<section class="relative w-full overflow-hidden bg-black lg:min-h-screen">
  <img
    src="/img/imagen2027/background_replus_2027.webp"
    alt="REPLUS MEXICO 2027 Background"
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-black/5"></div>
  <div class="relative z-10 flex flex-col lg:flex-wrap items-center justify-center gap-8 lg:gap-10 text-white text-center px-4 sm:px-8 lg:px-16 xl:px-24 py-10 sm:py-12 lg:min-h-screen" data-aos="fade-up" data-aos-duration="1000">
    <div class="flex flex-col sm:flex-row justify-center items-center w-full gap-4 sm:gap-6 lg:gap-8" data-aos="zoom-in" data-aos-duration="1100" data-aos-delay="100">
      <img
        src="/img/imagen2027/slogan.webp"
        alt="REPLUS MEXICO 2027 Slogan"
        class="w-full max-w-xs sm:max-w-sm md:max-w-lg lg:max-w-3xl h-auto"
        data-aos="fade-right"
        data-aos-duration="1000"
        data-aos-delay="200"
      />
      <img
          src={currentLanguage === "es"
            ? "/img/imagen2027/date_es_event_2027.webp"
            : "/img/imagen2027/date_en_event_2027.webp"}
          alt="Date Event"
          class="w-full max-w-xs sm:max-w-sm md:max-w-md lg:max-w-xl h-auto"
          data-aos="fade-left"
          data-aos-duration="1000"
          data-aos-delay="300"
        />
    </div>
    <p class="text-center lg:text-left text-xl md:text-2xl lg:text-3xl tracking-wide leading-relaxed font-semibold uppercase" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="400">
      {t("home.slogan")}
    </p>
  </div>
</section>
