---
import i18next, { t } from "i18next";

const sqmLabel = i18next.language === "es" ? "m2" : "sqm";

const currentLanguage = i18next.language;

const cards = [
  {
    icon: "/img/iconsegmentos2.png",
    metric: "+12,500",
    description: t("home.cifra_4"),
    duration: "1400",
  },
  {
    icon: "/img/iconsegmentos3.png",
    metric: "+165",
    description: t("home.cifra_5"),
    duration: "1800",
  },
  {
    icon: "/img/iconsegmentos1.png",
    metric: `+10,000 ${sqmLabel}`,
    description: t("home.cifra_3"),
    duration: "1600",
  },
  {
    icon: "/img/iconsegmentos4.png",
    metric: "+2,800",
    description: t("home.cifra_6"),
    duration: "1600",
  }
];
---

<section class="relative my-14 isolate">
  <h2 class="container mx-auto px-3 sm:px-4 md:px-6 text-center text-2xl font-extrabold tracking-tight text-purple-800 sm:text-3xl md:text-4xl py-10">
    {currentLanguage === "es" ? "UNA EDICION QUE MARCA EL RUMBO" : "AN EDITION THAT SETS THE COURSE"}
  </h2>

  <div class="container mx-auto px-3 sm:px-4 md:px-6">
    <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4 lg:gap-5">
      {
        cards.map((card) => (
          <article
            data-aos="fade-up"
            data-aos-duration={card.duration}
            class="group relative flex min-h-[155px] flex-col justify-end gap-2 overflow-hidden rounded-xl border border-blue-500/50 bg-gradient-to-br from-blue-900/70 via-purple-900/75 to-blue-950/85 p-3 shadow-lg shadow-blue-950/50 transition-all duration-300 backdrop-blur-sm hover:-translate-y-1 hover:border-blue-400/70 hover:shadow-xl hover:shadow-blue-800/70 sm:min-h-[190px] sm:rounded-2xl sm:p-4 md:min-h-[220px] md:p-5"
          >
            <div class="absolute inset-0 bg-gradient-to-tr from-blue-600/15 via-purple-700/10 to-transparent pointer-events-none" />
            <div class="absolute -top-16 -right-16 h-32 w-32 rounded-full bg-blue-500/15 blur-3xl pointer-events-none sm:-top-24 sm:-right-24 sm:h-48 sm:w-48" />

            <img
              src={card.icon}
              alt=""
              class="absolute right-2 top-2 h-8 w-8 object-contain opacity-95 drop-shadow-lg brightness-110 transition-all duration-300 group-hover:scale-110 sm:right-3 sm:top-3 sm:h-10 sm:w-10 md:right-4 md:top-4 md:h-12 md:w-12"
              loading="lazy"
            />

            {card.metric ? (
              <p class="relative z-10 pr-8 text-2xl font-extrabold leading-[0.95] text-white drop-shadow-lg sm:pr-10 sm:text-3xl md:text-4xl lg:text-[45px]">
                {card.metric}
              </p>
            ) : (
              <span class="relative z-10 inline-flex w-fit rounded-full border border-blue-400/60 bg-gradient-to-r from-blue-900/60 to-purple-950/60 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-widest text-white shadow-md backdrop-blur-sm sm:text-xs md:text-sm">
                RE+ MEXICO
              </span>
            )}

            <p class="relative z-10 max-w-[26ch] text-[11px] uppercase leading-snug text-white sm:max-w-[30ch] sm:text-xs md:text-sm lg:text-base">
              {card.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .bg-gradient-radial-purple {
    background:
      radial-gradient(
        circle at 15% 25%,
        rgba(30, 58, 138, 0.5),
        transparent 40%
      ),
      radial-gradient(
        circle at 85% 75%,
        rgba(88, 28, 135, 0.45),
        transparent 45%
      ),
      radial-gradient(
        circle at 50% 50%,
        rgba(55, 65, 181, 0.3),
        transparent 50%
      );
  }
</style>
